# Supabase Postgres (async driver). Session pooler URL, port 5432.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# openssl rand -hex 32
JWT_SECRET=change-me

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=service-role-key-never-ship-to-client

RESEND_API_KEY=re_xxxx

# Dev: vite default. Prod: https://<domain>
FRONTEND_ORIGIN=http://localhost:5173

# Dev: empty (host-only cookie). Prod: <domain> so api.<domain> cookies work.
COOKIE_DOMAIN=
