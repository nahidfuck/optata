# Supabase Postgres via the session pooler (port 5432), asyncpg driver.
# The FastAPI backend is the ONLY path to the DB — Data API is disabled.
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# openssl rand -hex 32
JWT_SECRET=change-me

SUPABASE_URL=https://xxxx.supabase.co
# Backend-only. Never in frontend code, never in a VITE_ variable, never in a response.
SUPABASE_SERVICE_KEY=service-role-key

RESEND_API_KEY=re_xxxx
# Sender for transactional email. resend.dev sender only delivers to your own inbox.
EMAIL_FROM=onboarding@resend.dev

# Dev: vite default. Prod: https://<domain>
FRONTEND_ORIGIN=http://localhost:5173

# Refresh-cookie flags. Local: false / lax / empty. Prod: true / lax / .<domain>
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Trusted reverse proxy peers for X-Forwarded-For (rate limiting keys on the
# resolved client IP). Local: 127.0.0.1. Prod (Render): the platform proxy.
# "*" only if the platform provably overwrites client-supplied XFF.
FORWARDED_ALLOW_IPS=127.0.0.1

# true → GET /debug/whoami reports resolved client IP / raw XFF / rate-limit
# key. Turn on temporarily during the Stage 6 audit, then back off.
DEBUG_WHOAMI=false
