# API base URL. Defaults to http://localhost:8000 when unset.
#
# Desktop dev:
#   VITE_API_BASE_URL=http://localhost:8000
#
# LAN / phone testing: use the machine's LAN IP for BOTH the API and the
# page you open (cookies are host-scoped — if the page is on localhost but
# the API on the LAN IP, the refresh cookie becomes cross-site and auth
# breaks). Open http://<lan-ip>:5173 on the phone AND on the desktop:
#   VITE_API_BASE_URL=http://192.168.0.201:8000
# The backend must then listen on the LAN too:
#   uv run uvicorn app.main:app --host 0.0.0.0 --port 8000
# and FRONTEND_ORIGIN in backend/.env must include http://<lan-ip>:5173.
VITE_API_BASE_URL=http://localhost:8000
